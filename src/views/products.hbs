<h2 style="color: #f59e0b; border-bottom: 2px solid #2d313a; padding-bottom: 0.5rem; margin-bottom: 2rem;">
    {{titulo}}
</h2>

<div id="productos-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem;">
    
    {{#each productos}}
    <div style="background-color: #1a1d24; border: 1px solid #2d313a; border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; justify-content: space-between;">
        <div>
            <span style="font-size: 0.8rem; background-color: #2d313a; color: #f59e0b; padding: 0.2rem 0.6rem; border-radius: 4px; font-weight: bold;">
                {{this.category}}
            </span>
            <h3 style="margin: 1rem 0 0.5rem 0; color: #fff;">{{this.title}}</h3>
            <p style="color: #9ca3af; font-size: 0.9rem; margin: 0 0 1.5rem 0; min-height: 40px;">
                {{this.description}}
            </p>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #2d313a; padding-top: 1rem; margin-top: auto;">
            <span style="font-size: 1.4rem; font-weight: bold; color: #10b981;">
                ${{this.price}}
            </span>
            <span style="font-size: 0.85rem; color: #9ca3af;">
                Stock: {{this.stock}}
            </span>
        </div>
    </div>
    {{/each}}

</div>

<script>
    socket.on('productoAgregado', (producto) => {
        console.log("¡El producto llegó al navegador!", producto);
        
        const grid = document.getElementById('productos-grid');
        
        const nuevaTarjeta = document.createElement('div');
        
        nuevaTarjeta.style.cssText = "background-color: #1a1d24; border: 1px solid #2d313a; border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; justify-content: space-between;";
        
        nuevaTarjeta.innerHTML = `
            <div>
                <span style="font-size: 0.8rem; background-color: #2d313a; color: #f59e0b; padding: 0.2rem 0.6rem; border-radius: 4px; font-weight: bold;">
                    ${producto.category}
                </span>
                <h3 style="margin: 1rem 0 0.5rem 0; color: #fff;">${producto.title}</h3>
                <p style="color: #9ca3af; font-size: 0.9rem; margin: 0 0 1.5rem 0; min-height: 40px;">
                    ${producto.description}
                </p>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #2d313a; padding-top: 1rem; margin-top: auto;">
                <span style="font-size: 1.4rem; font-weight: bold; color: #10b981;">
                    $${producto.price}
                </span>
                <span style="font-size: 0.85rem; color: #9ca3af;">
                    Stock: ${producto.stock}
                </span>
            </div>
        `;
        
        grid.appendChild(nuevaTarjeta);
    });
</script>